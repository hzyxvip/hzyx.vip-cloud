# 复制为 backend/.env 后修改（勿提交 .env 到 Git）
# 测试子域示例：https://test.hzyx.vip
# 现网旧系统（勿覆盖）：http://www.hzyx.vip/#/main

# 服务端口（与 Nginx / PM2 一致）
PORT=3006

# 生产环境务必改为长随机字符串（至少 32 位）
JWT_SECRET=请替换为随机长密钥-勿用默认值上公网
JWT_EXPIRES_IN=7d

# 可选：首次 seed 时创建外网测试用平台账号（用户名 GX00000-0）
# 留空则只创建 admin / demo / factory 演示账号
SEED_PLATFORM_TEST_USERNAME=GX00000-0
SEED_PLATFORM_TEST_PASSWORD=请设置强密码
SEED_PLATFORM_TEST_REAL_NAME=医享云平台测试账号
